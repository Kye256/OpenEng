  "combination_formula": {
    "uls_persistent_transient": "E_d = sum(gamma_G * G_k) + gamma_P * P + gamma_Q1 * Q_k1 + sum(gamma_Qi * psi_0i * Q_ki)",
    "uls_accidental": "E_d = sum(G_k) + P + A_d + psi_11 * Q_k1 + sum(psi_2i * Q_ki)",
    "uls_seismic": "E_d = sum(G_k) + P + A_Ed + sum(psi_2i * Q_ki)",
    "notation": {
      "gamma_G": "Partial factor for permanent action",
      "gamma_Q": "Partial factor for variable action",
      "psi_0": "Factor for combination value of variable action",
      "psi_1": "Factor for frequent value of variable action",
      "psi_2": "Factor for quasi-permanent value of variable action"
    }
