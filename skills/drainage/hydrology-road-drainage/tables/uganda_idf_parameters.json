  "short_duration_conversion": {
    "description": "Eqn 4.4: Converting 24-hour rainfall to shorter duration rainfall",
    "formula": "R_T = (T/24) * ((24 + b) / (b + T))^c * R_D",
    "notes": "R_T = rainfall in T hours (mm), R_D = daily rainfall (mm), b = 0.33 hrs, c from station tables. Daily rainfall from Appendix 4.3 (24-hour rainfall maps)"
  },
